{
  "name": "@denvig/sdk",
  "version": "0.7.0-alpha.4",
  "license": "MIT",
  "description": "Programmatic, in-process API for denvig — the logic layer behind the CLI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "denvig-source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./internal": {
      "denvig-source": "./src/internal.ts",
      "import": {
        "types": "./dist/internal.d.ts",
        "default": "./dist/internal.js"
      },
      "require": {
        "types": "./dist/internal.d.ts",
        "default": "./dist/internal.cjs"
      }
    },
    "./utils": {
      "denvig-source": "./src/utils.ts",
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.js"
      },
      "require": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.cjs"
      }
    },
    "./fs": {
      "denvig-source": "./src/fs.ts",
      "import": {
        "types": "./dist/fs.d.ts",
        "default": "./dist/fs.js"
      },
      "require": {
        "types": "./dist/fs.d.ts",
        "default": "./dist/fs.cjs"
      }
    },
    "./testing": {
      "denvig-source": "./src/test/mock.ts",
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && rolldown -c",
    "check-types": "tsc --noEmit",
    "codegen": "bin/codegen",
    "test": "node --test --conditions=denvig-source --test-skip-pattern='node_modules' 'src/**/*.test.ts'",
    "test:ci": "node --test --conditions=denvig-source --test-skip-pattern='node_modules' 'src/**/*.test.ts' --reporter=default"
  },
  "dependencies": {
    "node-forge": "^1.4.0",
    "semver": "^7.8.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@denvig/tsconfig": "workspace:*",
    "@types/node-forge": "^1.3.14",
    "@types/semver": "^7.7.1"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcqualie/denvig.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "cli",
    "node",
    "developer-tools",
    "productivity",
    "typescript",
    "sdk"
  ]
}
