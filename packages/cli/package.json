{
  "name": "@denvig/cli",
  "version": "0.7.0-alpha.6",
  "license": "MIT",
  "description": "A CLI tool to consistently manage cross-discipline projects",
  "type": "module",
  "bin": {
    "denvig": "./dist/cli.cjs"
  },
  "main": "./dist/sdk.cjs",
  "module": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "denvig-source": "./src/sdk.ts",
      "import": {
        "types": "./dist/sdk.d.ts",
        "default": "./dist/sdk.js"
      },
      "require": {
        "types": "./dist/sdk.d.ts",
        "default": "./dist/sdk.cjs"
      }
    },
    "./cli": {
      "denvig-source": "./src/cli.ts",
      "default": "./dist/cli.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && rolldown -c && chmod +x dist/cli.cjs",
    "check-types": "tsc --noEmit",
    "test": "node --test --conditions=denvig-source --test-skip-pattern='node_modules' 'src/**/*.test.ts'",
    "test:ci": "node --test --conditions=denvig-source --test-skip-pattern='node_modules' 'src/**/*.test.ts' --reporter=default"
  },
  "dependencies": {
    "@denvig/sdk": "workspace:*",
    "node-forge": "^1.4.0",
    "semver": "^7.8.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@denvig/tsconfig": "workspace:*",
    "@types/node-forge": "^1.3.14",
    "@types/semver": "^7.7.1"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcqualie/denvig.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "node",
    "developer-tools",
    "productivity",
    "typescript"
  ]
}
