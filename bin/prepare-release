#!/bin/bash

set -e

if [ -z "$1" ]; then
  echo "Usage: bin/prepare-release <tag>"
  echo "Example: bin/prepare-release v0.4.2"
  exit 1
fi

TAG="$1"

# Validate tag format (must start with 'v' followed by semver, optional prerelease)
if ! echo "$TAG" | grep -qE '^v[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.]+)?$'; then
  echo "Error: Tag must be in format vX.Y.Z or vX.Y.Z-prerelease (e.g., v0.4.2, v0.7.0-alpha.3)"
  exit 1
fi

# Extract version without 'v' prefix
VERSION="${TAG#v}"

# Get today's date in YYYY-MM-DD format
DATE=$(date +%Y-%m-%d)

echo "Preparing release $TAG ($DATE)"

# Bump the version in the workspace root and every package in lockstep.
# Using node for cross-platform JSON manipulation.
node -e "
const fs = require('fs');
const files = ['package.json', ...fs.readdirSync('packages').map((p) => 'packages/' + p + '/package.json').filter((f) => fs.existsSync(f))];
for (const file of files) {
  const pkg = JSON.parse(fs.readFileSync(file, 'utf8'));
  pkg.version = '$VERSION';
  fs.writeFileSync(file, JSON.stringify(pkg, null, 2) + '\n');
  console.log('Updated ' + file + ' version to $VERSION');
}
"

# Update CHANGELOG.md - replace [Unreleased] with [tag] - date
sed -i.bak "s/## \[Unreleased\]/## [$TAG] - $DATE/" CHANGELOG.md && rm CHANGELOG.md.bak
echo "Updated CHANGELOG.md [Unreleased] to [$TAG] - $DATE"

echo "Done! Review changes and commit when ready."
