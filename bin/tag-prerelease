#!/bin/bash
#
# Tag a new prerelease (alpha, beta, or rc) and publish it.
#
# Usage: bin/tag-prerelease vX.Y.Z-<channel>.<n>
#   e.g. bin/tag-prerelease v0.7.0-alpha.7
#
# Bumps every package.json in lockstep, adds a dated changelog entry below
# [Unreleased], commits and tags on main, then (after confirmation) pushes and
# creates a GitHub pre-release. The publish workflow then deploys to npm under a
# dist-tag matching the channel (alpha/beta/rc).
#
# Pass --yes to skip the push confirmation prompt.

set -euo pipefail

# shellcheck source=lib/release-common.sh
source "$(dirname "${BASH_SOURCE[0]}")/lib/release-common.sh"

export RELEASE_ASSUME_YES=0  # consumed by release_confirm in the sourced lib
TAG=""
for arg in "$@"; do
  case "$arg" in
    --yes|-y) RELEASE_ASSUME_YES=1 ;;
    -*) release_die "unknown option: $arg" ;;
    *) TAG="$arg" ;;
  esac
done

[ -n "$TAG" ] || release_die "usage: bin/tag-prerelease vX.Y.Z-<channel>.<n> (e.g. v0.7.0-alpha.7)"

# Strict prerelease format: vX.Y.Z-(alpha|beta|rc).N
if ! [[ "$TAG" =~ ^v[0-9]+\.[0-9]+\.[0-9]+-(alpha|beta|rc)\.[0-9]+$ ]]; then
  release_die "tag must be vX.Y.Z-<channel>.<n> where channel is alpha, beta, or rc (e.g. v0.7.0-alpha.7)"
fi

VERSION="${TAG#v}"
DATE="$(release_today)"
CURRENT="$(release_current_version)"

echo "Current version: $CURRENT"
echo "New prerelease:  $VERSION ($DATE)"

release_assert_greater "$VERSION" "$CURRENT"
release_assert_clean_main

release_bump_versions "$VERSION"
release_update_changelog "$VERSION" "$DATE"
release_commit_and_tag "$TAG"

echo
if release_confirm "Push $TAG and create the GitHub pre-release?"; then
  release_push_and_publish "$TAG" "$DATE" 1
  echo
  echo "Pushed. The publish workflow will deploy to npm under the matching dist-tag."
  echo "Track it: https://github.com/marcqualie/denvig/actions?query=branch%3Amain"
else
  echo "Skipped push. When ready, run:"
  echo "  git push && git push origin $TAG"
fi
